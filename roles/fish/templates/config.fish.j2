if test -f "$XDG_CONFIG_HOME/fish/fish_env"
  source "$XDG_CONFIG_HOME/fish/fish_env"
end

if test -f "$XDG_CONFIG_HOME/fish/.fish_aliases"
  source "$XDG_CONFIG_HOME/fish/.fish_aliases"
end

if set -q GHOSTTY_RESOURCES_DIR
  source "$GHOSTTY_RESOURCES_DIR"/shell-integration/fish/vendor_conf.d/ghostty-shell-integration.fish
end

set -U fish_greeting
if type -q fd
  set -gx FZF_DEFAULT_COMMAND 'fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
end
# set -gx FZF_CTRL_R_COMMAND ''
set -gx FZF_CTRL_T_OPTS "--walker-skip .git,node_modules,target --preview 'if test -d {}; eza --colour=auto --icons=auto --tree {}; else; bat -n --color=always --line-range=:500 {}; end' --bind 'ctrl-/:change-preview-window(down|hidden|)' --color header:italic --header 'Use `Ctrl + /` to toggle preview window'"
set -gx FZF_ALT_C_OPTS "--walker-skip .git,node_modules,target --preview 'eza --color=auto --icons=auto --tree {}'"

# if status is-interactive
# end

if type -q starship
  starship init fish | source
end

if type -q direnv
  direnv hook fish | source
end

if type -q fzf
  fzf --fish | source
end

if type -q zoxide
  zoxide init --cmd cd fish | source
end

