#!/usr/bin/env bash

set -x

VIRSH_GPU_VIDEO=pci_0000_01_00_0
VIRSH_GPU_AUDIO=pci_0000_01_00_1
VIRSH_USB=pci_0000_03_00_0

DATE=$(date +"%m/%d/%Y %R:%S :")
echo "$DATE Started start.sh (unbinding graphics from host)"

echo "Stopping gnome display manager"
systemctl stop gdm.service

echo "Unbinding virtual consoles"
for vt in /sys/class/vtconsole/vtcon*; do
  echo 0 > "$vt/bind" 2>/dev/null || true
done

echo "Unbinding pci devices"
echo $VIRSH_GPU_VIDEO > "/sys/bus/pci/devices/$VIRSH_GPU_VIDEO/driver/unbind"
echo $VIRSH_GPU_AUDIO > "/sys/bus/pci/devices/$VIRSH_GPU_AUDIO/driver/unbind"
echo $VIRSH_USB > "/sys/bus/pci/devices/$VIRSH_USB/driver/unbind"

echo "Unbinding EFI framebuffer"
echo efi-framebuffer.0 > /sys/bus/platform/drivers/efi-framebuffer/unbind 2>/dev/null || true

echo "Unloading nvidia drivers"
modprobe -r nvidia_drm
modprobe -r nvidia_uvm
modprobe -r nvidia_modeset
modprobe -r nvidia
modprobe -r drm_kms_helper
modprobe -r i2c_nvidia_gpu
modprobe -r drm

echo "Loading vfio kernel modules"
modprobe vfio
modprobe vfio_pci
modprobe vfio_iommu_type1

echo "$DATE Finished start.sh (unbinding graphics from host)"
